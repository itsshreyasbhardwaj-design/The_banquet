# ─────────────────────────────────────────────────────────────
# the Banquet by A.B.Corp — Environment Variable Reference
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in REAL values.
# NEVER commit .env.local or any file containing real secrets.
# This file (.env.example) contains ONLY placeholders — safe to commit.
# ─────────────────────────────────────────────────────────────

# Site URL (no trailing slash)
# Safe to expose publicly — used for OG tags and canonical URLs
NEXT_PUBLIC_SITE_URL=https://thebanquetabcorp.com

# ─── If you add analytics in the future ──────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX  # Google Analytics (public)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx            # PostHog (public)

# ─── If you add email/contact form in the future ─────────────
# RESEND_API_KEY=re_replace_me                # SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=replace_me
# SMTP_PASS=replace_me
# CONTACT_EMAIL=replace_me@example.com

# ─── If you add a database in the future ─────────────────────
# DATABASE_URL=replace_me                     # SERVER-SIDE ONLY

# ─── RULES ───────────────────────────────────────────────────
# NEXT_PUBLIC_* variables are VISIBLE IN THE BROWSER.
#   → Only put non-sensitive config here (site URL, public keys).
#   → NEVER put API secrets, tokens, or passwords as NEXT_PUBLIC_.
#
# All other variables are server-side only.
#   → They are never sent to the browser.
#   → Store them in Vercel Dashboard → Settings → Environment Variables.
